{
  "name": "react-frontend-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "precommit": "./scripts/precommit.sh",
    "preview": "vite preview",
    "test": "bun run test:component",
    "test:component": "env -u ELECTRON_RUN_AS_NODE -u DISPLAY -u WAYLAND_DISPLAY cypress run --component",
    "test:component:open": "env -u ELECTRON_RUN_AS_NODE -u DISPLAY -u WAYLAND_DISPLAY cypress open --component",
    "test:e2e": "env -u ELECTRON_RUN_AS_NODE -u DISPLAY -u WAYLAND_DISPLAY cypress run --e2e",
    "test:e2e:open": "env -u ELECTRON_RUN_AS_NODE -u DISPLAY -u WAYLAND_DISPLAY cypress open --e2e"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.30.1",
    "sass": "^1.89.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^4.6.0",
    "cypress": "^15.15.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4"
  }
}
